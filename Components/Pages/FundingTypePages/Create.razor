@page "/fundingtypes/create"
@using Microsoft.EntityFrameworkCore
@using StudentApplicationManagementSystem.Models
@inject IDbContextFactory<StudentApplicationManagementSystem.Data.StudentApplicationManagementSystemContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>FundingType</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="FundingType" OnValidSubmit="AddFundingType" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <span class="text-danger">*</span>
                <label for="fundingtypename" class="form-label">FundingTypeName:</label> 
                <InputText id="fundingtypename" @bind-Value="FundingType.FundingTypeName" class="form-control" aria-required="true"/> 
                <ValidationMessage For="() => FundingType.FundingTypeName" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/fundingtypes">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private FundingType FundingType { get; set; } = default!;

    protected override void OnInitialized() => FundingType ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddFundingType()
    {
        using var context = DbFactory.CreateDbContext();
        context.FundingType.Add(FundingType);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/fundingtypes");
    }
}
