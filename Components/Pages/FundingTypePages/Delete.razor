@page "/fundingtypes/delete"
@using Microsoft.EntityFrameworkCore
@using StudentApplicationManagementSystem.Models
@inject IDbContextFactory<StudentApplicationManagementSystem.Data.StudentApplicationManagementSystemContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>FundingType</h2>
    <hr />
    @if (fundingtype is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">FundingTypeName</dt>
            <dd class="col-sm-10">@fundingtype.FundingTypeName</dd>
        </dl>
        <EditForm method="post" Model="fundingtype" OnValidSubmit="DeleteFundingType" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(fundingtype is null)">Delete</button> |
            <a href="/fundingtypes">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private FundingType? fundingtype;

    [SupplyParameterFromQuery]
    private int FundingTypeId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        fundingtype = await context.FundingType.FirstOrDefaultAsync(m => m.FundingTypeId == FundingTypeId);

        if (fundingtype is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteFundingType()
    {
        using var context = DbFactory.CreateDbContext();
        context.FundingType.Remove(fundingtype!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/fundingtypes");
    }
}
