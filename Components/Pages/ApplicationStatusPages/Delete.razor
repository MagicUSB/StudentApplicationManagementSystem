@page "/applicationstatuses/delete"
@using Microsoft.EntityFrameworkCore
@using StudentApplicationManagementSystem.Models
@inject IDbContextFactory<StudentApplicationManagementSystem.Data.StudentApplicationManagementSystemContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>ApplicationStatus</h2>
    <hr />
    @if (applicationstatus is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">ApplicationStatusName</dt>
            <dd class="col-sm-10">@applicationstatus.ApplicationStatusName</dd>
        </dl>
        <EditForm method="post" Model="applicationstatus" OnValidSubmit="DeleteApplicationStatus" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(applicationstatus is null)">Delete</button> |
            <a href="/applicationstatuses">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private ApplicationStatus? applicationstatus;

    [SupplyParameterFromQuery]
    private int ApplicationStatusId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        applicationstatus = await context.ApplicationStatus.FirstOrDefaultAsync(m => m.ApplicationStatusId == ApplicationStatusId);

        if (applicationstatus is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteApplicationStatus()
    {
        using var context = DbFactory.CreateDbContext();
        context.ApplicationStatus.Remove(applicationstatus!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/applicationstatuses");
    }
}
