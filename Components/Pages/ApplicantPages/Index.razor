@page "/applicants"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using StudentApplicationManagementSystem.Models
@using StudentApplicationManagementSystem.Data
@implements IAsyncDisposable
@inject IDbContextFactory<StudentApplicationManagementSystem.Data.StudentApplicationManagementSystemContext> DbFactory

<PageTitle>Index</PageTitle>

<h1>Список абітурієнтів</h1>

<p>
    <a href="applicants/create">Додати абітурієнта</a>
</p>

<QuickGrid Class="table" Items="context.Applicant">
    <PropertyColumn Property="applicant => applicant.ApplicantSurname" Sortable="true" Title="Прізвище"/>
    <PropertyColumn Property="applicant => applicant.ApplicantName" Title="Ім'я"/>
    <PropertyColumn Property="applicant => applicant.ApplicantPatronymic" Title="По батькові"/>
    <PropertyColumn Property="applicant => applicant.ApplicantTelephone" Title="Телефон"/>

    <TemplateColumn Context="applicant">
        <a href="@($"applicants/edit?applicantid={applicant.ApplicantId}")">Редагувати</a> |
        <a href="@($"applicants/delete?applicantid={applicant.ApplicantId}")">Видалити</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private StudentApplicationManagementSystemContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
