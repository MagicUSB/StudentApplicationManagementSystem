@page "/degrees/edit"
@using Microsoft.EntityFrameworkCore
@using StudentApplicationManagementSystem.Models
@inject IDbContextFactory<StudentApplicationManagementSystem.Data.StudentApplicationManagementSystemContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Degree</h2>
<hr />
@if (Degree is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Degree" OnValidSubmit="UpdateDegree" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Degree.DegreeId" value="@Degree.DegreeId" />
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="degreename" class="form-label">DegreeName:</label>
                    <InputText id="degreename" @bind-Value="Degree.DegreeName" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Degree.DegreeName" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/degrees">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int DegreeId { get; set; }

    [SupplyParameterFromForm]
    private Degree? Degree { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Degree ??= await context.Degree.FirstOrDefaultAsync(m => m.DegreeId == DegreeId);

        if (Degree is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateDegree()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(Degree!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!DegreeExists(Degree!.DegreeId))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/degrees");
    }

    private bool DegreeExists(int degreeid)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Degree.Any(e => e.DegreeId == degreeid);
    }
}
