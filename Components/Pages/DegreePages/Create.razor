@page "/degrees/create"
@using Microsoft.EntityFrameworkCore
@using StudentApplicationManagementSystem.Models
@inject IDbContextFactory<StudentApplicationManagementSystem.Data.StudentApplicationManagementSystemContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Degree</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Degree" OnValidSubmit="AddDegree" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <span class="text-danger">*</span>
                <label for="degreename" class="form-label">DegreeName:</label> 
                <InputText id="degreename" @bind-Value="Degree.DegreeName" class="form-control" aria-required="true"/> 
                <ValidationMessage For="() => Degree.DegreeName" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/degrees">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Degree Degree { get; set; } = default!;

    protected override void OnInitialized() => Degree ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddDegree()
    {
        using var context = DbFactory.CreateDbContext();
        context.Degree.Add(Degree);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/degrees");
    }
}
