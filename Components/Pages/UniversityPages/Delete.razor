@page "/universities/delete"
@using Microsoft.EntityFrameworkCore
@using StudentApplicationManagementSystem.Models
@inject IDbContextFactory<StudentApplicationManagementSystem.Data.StudentApplicationManagementSystemContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>University</h2>
    <hr />
    @if (university is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Назва ЗВО</dt>
            <dd class="col-sm-10">@university.UniversityName</dd>
        </dl>
        <EditForm method="post" Model="university" OnValidSubmit="DeleteUniversity" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(university is null)">Delete</button> |
            <a href="/universities">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private University? university;

    [SupplyParameterFromQuery]
    private int UniversityId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        university = await context.University.FirstOrDefaultAsync(m => m.UniversityId == UniversityId);

        if (university is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteUniversity()
    {
        using var context = DbFactory.CreateDbContext();
        context.University.Remove(university!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/universities");
    }
}
